# ============================================================
# MCP DevBridge - Environment Variables Template
# Copy to .env.production and fill in values before deploying
# ============================================================

# --- GitHub MCP Server ---
# Personal access token for GitHub API access
# Generate at: https://github.com/settings/tokens
GITHUB_TOKEN=ghp_your_github_personal_access_token_here

# --- Public Access ---
# Port Nginx listens on (default: 80)
PUBLIC_PORT=80
